<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<fx:root height="560.0" resizable="false" title="Help" type="javafx.stage.Stage" width="720.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@DarkTheme.css" />
        <URL value="@Extensions.css" />
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <VBox fx:id="helpWindowContainer" spacing="16.0" styleClass="background">
        <children>
          <VBox fx:id="helpHeaderCard" spacing="6.0">
            <children>
              <Label styleClass="label-header" text="Command Guide" />
              <Label fx:id="helpSubtitle" styleClass="label-bright"
                     text="Everything you can type into ManageUp, with formats and examples in one place." wrapText="true" />
            </children>
          </VBox>
          <StackPane styleClass="result-display-shell" VBox.vgrow="ALWAYS">
            <TextArea fx:id="helpContent" editable="false" focusTraversable="false" prefHeight="420.0"
                      wrapText="true" styleClass="help-display" />
          </StackPane>
          <HBox alignment="CENTER_RIGHT" fx:id="helpFooterBar" spacing="10.0">
            <children>
              <Label fx:id="helpFooterText" text="Need the full guide too?" />
              <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy User Guide URL" />
            </children>
          </HBox>
        </children>
        <padding>
          <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
        </padding>
      </VBox>
    </Scene>
  </scene>
</fx:root>
